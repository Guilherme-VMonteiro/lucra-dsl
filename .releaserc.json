{
  "branches": ["main"],
  "tagFormat": "v${version}",
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    "@semantic-release/github",
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "cd lucradsl.parent/lucradsl && mvn versions:set -DnewVersion=${nextRelease.version} -DgenerateBackupPoms=false",
        "publishCmd": "cd lucradsl.parent/lucradsl && mvn -B clean deploy"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["lucradsl.parent/lucradsl/pom.xml"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ]
  ]
}
