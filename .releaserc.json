{
  "branches": ["main"],
  "tagFormat": "v${version}",
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    "@semantic-release/github",
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "cd lucradsl.parent && mvn org.eclipse.tycho:tycho-versions-plugin:set-version -DnewVersion=${nextRelease.version}",
        "publishCmd": "cd lucradsl.parent && mvn -B install -pl lucradsl.target -DskipTests && mvn -B clean deploy -pl lucradsl"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": [
          "lucradsl.parent/pom.xml",
          "lucradsl.parent/*/pom.xml",
          "lucradsl.parent/*/META-INF/MANIFEST.MF"
        ],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ]
  ]
}
